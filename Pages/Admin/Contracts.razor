@page "/admin/contracts"
@inject IDataService Data
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<MudText Typo="Typo.h5" Style="font-weight: bold;" Class="mb-4">חוזי התקשרות עם לקוחות</MudText>
<MudAlert Severity="Severity.Info" Dense="true" Class="mb-4">מידע זה חסום לחלוטין לצפיית מאמנים - נגיש למנהלים בלבד</MudAlert>

<MudSelect T="string" Value="selectedClientId" ValueChanged="LoadContracts" Label="בחר לקוח" Variant="Variant.Outlined" Class="mb-4">
    @foreach (var c in clients)
    {
        <MudSelectItem Value="@c.ClientId">@c.ClientName</MudSelectItem>
    }
</MudSelect>

@if (!string.IsNullOrEmpty(selectedClientId))
{
    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
        <MudText Typo="Typo.h6">הסכמים פעילים</MudText>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" OnClick="AddContract">הוסף הסכם</MudButton>
    </MudStack>

    <MudTable Items="contracts" Hover="true" Elevation="2" Dense="true">
        <HeaderContent>
            <MudTh>תעריף חיוב (₪/שעה)</MudTh>
            <MudTh>היקף שעות</MudTh>
            <MudTh>תנאי תשלום</MudTh>
            <MudTh>תקופה</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd Style="font-weight: bold;">₪@context.BillingRatePerHour</MudTd>
            <MudTd>@context.WorkScopeHours</MudTd>
            <MudTd>@context.PaymentTerms</MudTd>
            <MudTd>@context.StartDate.ToString("dd/MM/yyyy") - @(context.EndDate?.ToString("dd/MM/yyyy") ?? "פתוח")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    private List<ClientOrg> clients = new();
    private List<ClientContract> contracts = new();
    private string selectedClientId = "";

    protected override async Task OnInitializedAsync()
    {
        try { clients = await Data.GetClientsAsync(); } catch { }
    }

    private async Task LoadContracts(string clientId)
    {
        selectedClientId = clientId;
        if (string.IsNullOrEmpty(clientId)) return;
        try { contracts = await Data.GetContractsByClientAsync(clientId); } catch { }
    }

    private async Task AddContract()
    {
        var contract = new ClientContract { ClientId = selectedClientId };
        var parameters = new DialogParameters<ContractDialog> { { x => x.Contract, contract } };
        var dialog = await Dialog.ShowAsync<ContractDialog>("הוספת הסכם", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ClientContract newContract })
        {
            try
            {
                await Data.CreateContractAsync(newContract);
                contracts = await Data.GetContractsByClientAsync(selectedClientId);
                Snackbar.Add("הסכם נוסף", Severity.Success);
            }
            catch (Exception ex) { Snackbar.Add($"שגיאה: {ex.Message}", Severity.Error); }
        }
    }
}
