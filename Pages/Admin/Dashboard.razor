@page "/admin/dashboard"
@inject IDataService Data
@inject AppState AppState
@inject NavigationManager Nav
@inject NotificationService NotificationSvc

<MudText Typo="Typo.h5" Style="font-weight: bold;" Class="mb-4">לוח בקרה - סקירה כללית</MudText>

@if (_loading)
{
    <MudOverlay Visible="true" DarkBackground="false" Absolute="false">
        <MudStack AlignItems="AlignItems.Center" Spacing="2">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
            <MudText Typo="Typo.body1">טוען נתונים...</MudText>
        </MudStack>
    </MudOverlay>
}

@if (errorMessage != null)
{
    <MudAlert Severity="Severity.Error" Class="mb-4">שגיאה: @errorMessage</MudAlert>
}

<MudGrid>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2" Class="pa-4 rounded-lg cursor-pointer" Style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo("admin/coaches"))">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Primary" Style="font-size: 2.5rem;" />
                <MudText Typo="Typo.h4" Style="font-weight: bold;">@coachCount</MudText>
                <MudText Typo="Typo.caption">מאמנים פעילים</MudText>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2" Class="pa-4 rounded-lg" Style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo("admin/clients"))">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Business" Color="Color.Secondary" Style="font-size: 2.5rem;" />
                <MudText Typo="Typo.h4" Style="font-weight: bold;">@clientCount</MudText>
                <MudText Typo="Typo.caption">לקוחות פעילים</MudText>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2" Class="pa-4 rounded-lg" Style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo("admin/assignments"))">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Info" Style="font-size: 2.5rem;" />
                <MudText Typo="Typo.h4" Style="font-weight: bold;">@assignmentCount</MudText>
                <MudText Typo="Typo.caption">שיבוצים פעילים</MudText>
            </MudStack>
        </MudCard>
    </MudItem>
    <MudItem xs="6" sm="3">
        <MudCard Elevation="2" Class="pa-4 rounded-lg" Style="cursor:pointer;" @onclick="@(() => Nav.NavigateTo("admin/time-reports"))">
            <MudStack AlignItems="AlignItems.Center">
                <MudIcon Icon="@Icons.Material.Filled.PendingActions" Color="Color.Warning" Style="font-size: 2.5rem;" />
                <MudText Typo="Typo.h4" Style="font-weight: bold;">@pendingEntries</MudText>
                <MudText Typo="Typo.caption">דיווחים ממתינים</MudText>
            </MudStack>
        </MudCard>
    </MudItem>
</MudGrid>

<MudGrid Class="mt-4">
    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="pa-4 rounded-lg">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">מסמכים לאישור</MudText>
                <MudChip T="string" Size="Size.Small" Color="Color.Warning">@pendingDocs.Count</MudChip>
            </MudStack>
            @if (pendingDocs.Any())
            {
                <MudList T="CoachDocument" Dense="true">
                    @foreach (var doc in pendingDocs.Take(5))
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Description">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText>@GetCoachName(doc.CoachId) - @GetDocTypeText(doc.DocType)</MudText>
                                <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Primary" Href="admin/documents">צפה</MudButton>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
                @if (pendingDocs.Count > 5)
                {
                    <MudButton Variant="Variant.Text" Color="Color.Primary" FullWidth="true" Href="admin/documents">צפה בכל @pendingDocs.Count המסמכים</MudButton>
                }
            }
            else
            {
                <MudText Color="Color.Default">אין מסמכים ממתינים לאישור</MudText>
            }
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-3">דיווחי שעות אחרונים</MudText>
            @if (recentEntries.Any())
            {
                <MudList T="TimeEntry" Dense="true">
                    @foreach (var entry in recentEntries.Take(5))
                    {
                        <MudListItem Icon="@Icons.Material.Filled.Schedule">
                            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudText>@entry.WorkDate.ToString("dd/MM") - @entry.HoursReported שעות</MudText>
                                <MudChip T="string" Size="Size.Small" Color="@GetStatusColor(entry.Status)">@GetStatusText(entry.Status)</MudChip>
                            </MudStack>
                        </MudListItem>
                    }
                </MudList>
            }
            else
            {
                <MudText Color="Color.Default">אין דיווחים להצגה</MudText>
            }
        </MudCard>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudCard Elevation="2" Class="pa-4 rounded-lg">
            <MudText Typo="Typo.h6" Class="mb-3">פעולות מהירות</MudText>
            <MudStack Spacing="2">
                <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.PersonAdd" Href="admin/coaches">הוסף מאמן חדש</MudButton>
                <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.BusinessCenter" Href="admin/clients">הוסף לקוח חדש</MudButton>
                <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.Add" Href="admin/assignments">צור שיבוץ חדש</MudButton>
                <MudButton Variant="Variant.Outlined" FullWidth="true" StartIcon="@Icons.Material.Filled.Checklist" Href="admin/time-reports">אשר דיווחי שעות</MudButton>
            </MudStack>
        </MudCard>
    </MudItem>
</MudGrid>

@code {
    private int coachCount, clientCount, assignmentCount, pendingEntries;
    private List<TimeEntry> recentEntries = new();
    private List<CoachDocument> pendingDocs = new();
    private List<Coach> coaches = new();
    private string? errorMessage;
    private bool _loading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Load core counts in parallel
            var coachesTask = Data.GetCoachesAsync();
            var clientsTask = Data.GetClientsAsync();
            var assignmentsTask = Data.GetAssignmentsAsync();
            var entriesTask = Data.GetTimeEntriesAsync();

            await Task.WhenAll(coachesTask, clientsTask, assignmentsTask, entriesTask);

            coaches = coachesTask.Result;
            coachCount = coaches.Count;
            clientCount = clientsTask.Result.Count;

            var assignments = assignmentsTask.Result;
            assignmentCount = assignments.Count(a => a.Status == "Active");

            recentEntries = entriesTask.Result;
            pendingEntries = recentEntries.Count(e => e.Status is "Pending_Signature" or "Client_Approved");

            // Show partial data immediately
            _loading = false;
            StateHasChanged();

            // Load pending documents in parallel (background)
            var docTasks = coaches.Select(c => Data.GetDocumentsByCoachAsync(c.CoachId));
            var allDocs = await Task.WhenAll(docTasks);
            pendingDocs = allDocs.SelectMany(docs => docs.Where(d => d.Status == "Pending_Review")).ToList();

            // Refresh notification badge (background)
            _ = NotificationSvc.RefreshNotificationCountAsync();
        }
        catch (Exception ex)
        {
            errorMessage = ex.Message;
            Console.WriteLine($"Dashboard error: {ex}");
        }
        finally
        {
            _loading = false;
        }
    }

    private string GetCoachName(string coachId)
    {
        var c = coaches.FirstOrDefault(x => x.CoachId == coachId);
        return c is not null ? $"{c.FirstName} {c.LastName}" : "מאמן";
    }

    private string GetDocTypeText(string t) => t switch
    {
        "National_ID_Card" => "תעודת זהות",
        "Police_Clearance" => "אישור משטרה",
        "Certification" => "תעודת הסמכה",
        "Tax_Withholding" => "ניכוי מס במקור",
        "Bank_Confirmation" => "אישור ניהול חשבון",
        "Contract" => "חוזה",
        _ => t
    };

    private Color GetStatusColor(string status) => status switch
    {
        "Pending_Signature" => Color.Warning,
        "Client_Approved" => Color.Info,
        "Admin_Approved" => Color.Success,
        "Billed_Paid" => Color.Default,
        _ => Color.Default
    };

    private string GetStatusText(string status) => status switch
    {
        "Pending_Signature" => "ממתין לחתימה",
        "Client_Approved" => "נחתם",
        "Admin_Approved" => "אושר",
        "Billed_Paid" => "שולם",
        _ => status
    };
}
