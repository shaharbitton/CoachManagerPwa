@page "/admin/clients"
@inject IDataService Data
@inject IDialogService Dialog
@inject ISnackbar Snackbar

<MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-4">
    <MudText Typo="Typo.h5" Style="font-weight: bold;">ניהול לקוחות ומוסדות</MudText>
    <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.AddBusiness" OnClick="OpenAddDialog">הוסף לקוח</MudButton>
</MudStack>

<MudTextField @bind-Value="searchText" Placeholder="חיפוש לפי שם, עיר או סוג..."
              Variant="Variant.Outlined" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
              Immediate="true" Class="mb-4" />

<MudTable Items="FilteredClients" Hover="true" Elevation="2" Dense="true" Loading="loading">
    <HeaderContent>
        <MudTh>שם הלקוח</MudTh>
        <MudTh>סוג</MudTh>
        <MudTh>עיר</MudTh>
        <MudTh>סטטוס</MudTh>
        <MudTh>פעולות</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd>@context.ClientName</MudTd>
        <MudTd><MudChip T="string" Size="Size.Small" Color="Color.Info">@GetTypeText(context.ClientType)</MudChip></MudTd>
        <MudTd>@context.City</MudTd>
        <MudTd>
            <MudChip T="string" Size="Size.Small" Color="@(context.IsActive ? Color.Success : Color.Default)">
                @(context.IsActive ? "פעיל" : "לא פעיל")
            </MudChip>
        </MudTd>
        <MudTd>
            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small" OnClick="@(() => EditClient(context))" />
            <MudIconButton Icon="@Icons.Material.Filled.Description" Size="Size.Small" Color="Color.Info" OnClick="@(() => ViewContracts(context))" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText Align="Align.Center" Class="pa-4">לא נמצאו לקוחות</MudText>
    </NoRecordsContent>
</MudTable>

@code {
    private List<ClientOrg> clients = new();
    private string searchText = "";
    private bool loading = true;

    private IEnumerable<ClientOrg> FilteredClients => string.IsNullOrWhiteSpace(searchText)
        ? clients
        : clients.Where(c =>
            c.ClientName.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            (c.City ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
            c.ClientType.Contains(searchText, StringComparison.OrdinalIgnoreCase));

    protected override async Task OnInitializedAsync()
    {
        try { clients = await Data.GetClientsAsync(); }
        catch { }
        finally { loading = false; }
    }

    private async Task OpenAddDialog()
    {
        var parameters = new DialogParameters<ClientDialog> { { x => x.Client, new ClientOrg() }, { x => x.IsNew, true } };
        var dialog = await Dialog.ShowAsync<ClientDialog>("הוספת לקוח חדש", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ClientOrg newClient })
        {
            try
            {
                await Data.CreateClientAsync(newClient);
                clients.Add(newClient);
                Snackbar.Add("לקוח נוסף בהצלחה", Severity.Success);
            }
            catch (Exception ex) { Snackbar.Add($"שגיאה: {ex.Message}", Severity.Error); }
        }
    }

    private async Task EditClient(ClientOrg client)
    {
        var parameters = new DialogParameters<ClientDialog> { { x => x.Client, client }, { x => x.IsNew, false } };
        var dialog = await Dialog.ShowAsync<ClientDialog>("עריכת לקוח", parameters, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: ClientOrg updated })
        {
            try
            {
                await Data.UpdateClientAsync(updated);
                Snackbar.Add("לקוח עודכן", Severity.Success);
                clients = await Data.GetClientsAsync();
            }
            catch (Exception ex) { Snackbar.Add($"שגיאה: {ex.Message}", Severity.Error); }
        }
    }

    private void ViewContracts(ClientOrg client)
    {
        // Navigate to contracts view
    }

    private string GetTypeText(string type) => type switch
    {
        "School" => "בית ספר",
        "Community_Center" => "מתנ\"ס",
        "NGO" => "עמותה",
        "Private_Client" => "פרטי",
        _ => type
    };
}
