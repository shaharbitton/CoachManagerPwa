@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudGrid>
            @if (IsNew)
            {
                <MudItem xs="12">
                    <MudTextField @bind-Value="Email" Label="אימייל המאמן" Variant="Variant.Outlined" Required="true"
                                  InputType="InputType.Email" Style="direction: ltr; text-align: left;"
                                  HelperText="סיסמה דיפולטית: Coach123! (המאמן יחליף בכניסה ראשונה)" />
                </MudItem>
            }
            <MudItem xs="6">
                <MudTextField @bind-Value="Coach.FirstName" Label="שם פרטי" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="Coach.LastName" Label="שם משפחה" Variant="Variant.Outlined" Required="true" />
            </MudItem>
            <MudItem xs="6">
                <MudDatePicker @bind-Date="birthDate" Label="תאריך לידה" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="6">
                <MudTextField @bind-Value="Coach.Occupation" Label="מקצוע / עיסוק" Variant="Variant.Outlined" />
            </MudItem>
            <MudItem xs="12">
                <MudSelect T="string" @bind-Value="Coach.TaxStatus" Label="מעמד מיסויי" Variant="Variant.Outlined">
                    <MudSelectItem Value="@("Employee")">שכיר</MudSelectItem>
                    <MudSelectItem Value="@("Exempt_Dealer")">עוסק פטור</MudSelectItem>
                    <MudSelectItem Value="@("Licensed_Dealer")">עוסק מורשה</MudSelectItem>
                </MudSelect>
            </MudItem>
        </MudGrid>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">ביטול</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@(IsNew ? "צור מאמן" : "עדכן")</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public Coach Coach { get; set; } = new();
    [Parameter] public bool IsNew { get; set; }
    [Parameter] public string Email { get; set; } = "";

    private DateTime? birthDate;

    protected override void OnParametersSet()
    {
        birthDate = Coach.BirthDate;
    }

    private void Submit()
    {
        if (IsNew && string.IsNullOrWhiteSpace(Email))
        {
            Snackbar.Add("יש להזין אימייל למאמן", Severity.Warning);
            return;
        }
        if (string.IsNullOrWhiteSpace(Coach.FirstName) || string.IsNullOrWhiteSpace(Coach.LastName))
        {
            Snackbar.Add("שם פרטי ושם משפחה הם שדות חובה", Severity.Warning);
            return;
        }
        Coach.BirthDate = birthDate;
        MudDialog.Close(DialogResult.Ok(new CoachDialogResult { Coach = Coach, Email = Email }));
    }

    private void Cancel() => MudDialog.Cancel();
}
