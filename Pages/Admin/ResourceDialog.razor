<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="Resource.Title" Label="כותרת" Variant="Variant.Outlined" Required="true" />
        <MudTextField @bind-Value="Resource.Description" Label="תיאור והכוונה פדגוגית" Variant="Variant.Outlined" Lines="3" Class="mt-3" />
        <MudTextField @bind-Value="Resource.SkillCategory" Label="קטגוריה (ספורט, רובוטיקה...)" Variant="Variant.Outlined" Class="mt-3" />
        <MudSelect T="string" @bind-Value="Resource.TargetAgeGroup" Label="שכבת גיל" Variant="Variant.Outlined" Class="mt-3">
            <MudSelectItem Value="@("יסודי")">יסודי</MudSelectItem>
            <MudSelectItem Value="@("חטיבה")">חטיבה</MudSelectItem>
            <MudSelectItem Value="@("תיכון")">תיכון</MudSelectItem>
            <MudSelectItem Value="@("חינוך מיוחד")">חינוך מיוחד</MudSelectItem>
        </MudSelect>
        <MudFileUpload T="IBrowserFile" Accept=".pdf,.png,.jpg,.jpeg,.doc,.docx,.pptx,.xlsx" FilesChanged="OnFileSelected" MaximumFileCount="1">
            <ActivatorContent>
                <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload" FullWidth="true" Class="mt-3">
                    @(selectedFile is not null ? selectedFile.Name : "העלאת קובץ מצורף")
                </MudButton>
            </ActivatorContent>
        </MudFileUpload>
        @if (uploading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-2" />
        }
        @if (!string.IsNullOrEmpty(Resource.AttachmentUrl))
        {
            <MudAlert Severity="Severity.Success" Class="mt-2" Dense="true">קובץ הועלה: @Path.GetFileName(Resource.AttachmentUrl)</MudAlert>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">ביטול</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="uploading">הוסף</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = default!;
    [Parameter] public TrainingResource Resource { get; set; } = new();
    [Inject] private Supabase.Client SupabaseClient { get; set; } = default!;
    [Inject] private ISnackbar Snackbar { get; set; } = default!;

    private IBrowserFile? selectedFile;
    private bool uploading;

    private async Task OnFileSelected(IBrowserFile file)
    {
        selectedFile = file;
        uploading = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 20 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            var fileBytes = ms.ToArray();

            var ext = Path.GetExtension(file.Name);
            var fileName = $"resources/{Resource.SkillCategory ?? "general"}/{DateTime.UtcNow:yyyyMMdd_HHmmss}_{file.Name}";

            await SupabaseClient.Storage.From("resources").Upload(fileBytes, fileName, new Supabase.Storage.FileOptions
            {
                ContentType = file.ContentType
            });

            Resource.AttachmentUrl = SupabaseClient.Storage.From("resources").GetPublicUrl(fileName);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"שגיאה בהעלאה: {ex.Message}", Severity.Error);
        }
        finally { uploading = false; }
    }

    private void Submit()
    {
        if (string.IsNullOrWhiteSpace(Resource.Title)) return;
        MudDialog.Close(DialogResult.Ok(Resource));
    }

    private void Cancel() => MudDialog.Cancel();
}
