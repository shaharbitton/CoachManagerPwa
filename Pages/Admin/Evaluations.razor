@page "/admin/evaluations"
@inject IDataService Data
@inject ISnackbar Snackbar

<MudText Typo="Typo.h5" Style="font-weight: bold;" Class="mb-4">הערכות מאמנים - תיק סודי</MudText>
<MudAlert Severity="Severity.Warning" Dense="true" Class="mb-4">מידע HR סודי - אינו נגיש למאמנים</MudAlert>

<MudSelect T="string" @bind-Value="selectedCoachId" Label="בחר מאמן" Variant="Variant.Outlined" Class="mb-4">
    @foreach (var c in coaches)
    {
        <MudSelectItem Value="@c.CoachId">@c.FirstName @c.LastName</MudSelectItem>
    }
</MudSelect>

@if (!string.IsNullOrEmpty(selectedCoachId))
{
    <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
        <MudTabPanel Text="הערכות ביצוע" Icon="@Icons.Material.Filled.Star">
            <MudText Typo="Typo.subtitle1" Class="mb-2">יומן הערכות</MudText>
            <MudText Color="Color.Default">טעינת הערכות מהשרת...</MudText>
            <!-- evaluations list will load from API -->
        </MudTabPanel>
        <MudTabPanel Text="תגיות אופי" Icon="@Icons.Material.Filled.Label">
            <MudText Typo="Typo.subtitle1" Class="mb-2">מיומנויות רכות ותגיות אופי</MudText>
            <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                <MudChip T="string" Color="Color.Primary" Size="Size.Medium">בעל משמעת חזקה</MudChip>
                <MudChip T="string" Color="Color.Info" Size="Size.Medium">מצוין לחינוך מיוחד</MudChip>
                <MudChip T="string" Color="Color.Warning" Size="Size.Medium">אסרטיבי</MudChip>
            </MudStack>
            <MudTextField T="string" Placeholder="הוסף תגית חדשה..." Variant="Variant.Outlined" Class="mt-3"
                          Adornment="Adornment.End" AdornmentIcon="@Icons.Material.Filled.Add" />
        </MudTabPanel>
    </MudTabs>
}

@code {
    private List<Coach> coaches = new();
    private string selectedCoachId = "";

    protected override async Task OnInitializedAsync()
    {
        try { coaches = await Data.GetCoachesAsync(); } catch { }
    }
}
