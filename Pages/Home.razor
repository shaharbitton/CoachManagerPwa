@page "/"
@inject Supabase.Client SupabaseClient
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager Nav
@inject IDataService DataService

<MudStack AlignItems="AlignItems.Center" Class="mt-8">
    <MudIcon Icon="@Icons.Material.Filled.Shield" Style="font-size: 4rem; color: #1a365d;" />
    <MudText Typo="Typo.h4" Style="font-weight: bold; color: #1a365d;">ניהול מאמנים ושטח</MudText>
    <MudText Typo="Typo.subtitle1" Color="Color.Default">מסך כניסה מאובטח</MudText>
</MudStack>

<MudCard Elevation="4" Class="rounded-lg pa-6 mt-6">
    <MudTextField @bind-Value="email" Label="אימייל" Variant="Variant.Outlined" Class="mb-3"
                  InputType="InputType.Email" Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email"
                  Style="direction: ltr; text-align: left;" />
    <MudTextField @bind-Value="password" Label="סיסמה" InputType="InputType.Password" Variant="Variant.Outlined" Class="mb-4"
                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock"
                  Style="direction: ltr; text-align: left;" />

    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Size="Size.Large"
               OnClick="Login" Disabled="loading" Class="mb-3">
        @if (loading)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" Class="me-2" />
        }
        התחבר למערכת
    </MudButton>
</MudCard>

@code {
    private string email = "";
    private string password = "";
    private bool loading;

    private async Task Login()
    {
        loading = true;
        try
        {
            var session = await SupabaseClient.Auth.SignIn(email, password);
            if (session != null)
            {
                await DataService.RefreshAuthAsync();

                var role = "Coach";
                try
                {
                    var urResponse = await SupabaseClient.From<UserRole>()
                        .Where(ur => ur.UserId == session.User!.Id)
                        .Get();
                    var userRoles = urResponse.Models;
                    if (userRoles.Count > 0)
                    {
                        var roleIds = userRoles.Select(ur => ur.RoleId).ToList();
                        var rolesResponse = await SupabaseClient.From<Role>().Get();
                        var allRoles = rolesResponse.Models;
                        var userRoleNames = allRoles
                            .Where(r => roleIds.Contains(r.RoleId))
                            .Select(r => r.RoleName)
                            .ToList();

                        if (userRoleNames.Contains("Admin"))
                            role = "Admin";
                        else if (userRoleNames.Contains("Operations_Lead"))
                            role = "Operations_Lead";
                        else if (userRoleNames.Count > 0)
                            role = userRoleNames.First();
                    }
                }
                catch { /* fallback to Coach */ }

                AppState.SetUser(session.User!.Id, session.User.Email ?? "משתמש", role);

                // Check if coach needs onboarding (first login)
                if (AppState.IsCoach)
                {
                    try
                    {
                        var coach = await DataService.GetCoachByIdAsync(session.User!.Id);
                        var docs = await DataService.GetDocumentsByCoachAsync(session.User!.Id);

                        var hasIdDoc = docs.Any(d => d.DocType == "National_ID_Card");
                        var hasPoliceClearance = docs.Any(d => d.DocType == "Police_Clearance");
                        var hasCertification = docs.Any(d => d.DocType == "Certification");

                        bool profileIncomplete = coach is null
                            || string.IsNullOrWhiteSpace(coach.FirstName)
                            || string.IsNullOrWhiteSpace(coach.LastName)
                            || string.IsNullOrWhiteSpace(coach.NationalId);

                        bool missingDocs = !hasIdDoc || !hasPoliceClearance || !hasCertification;

                        // If logged in with default password or profile/docs incomplete → onboarding
                        if (password == "Coach123!" || profileIncomplete || missingDocs)
                        {
                            AppState.RequiresOnboarding = true;
                            AppState.UsedDefaultPassword = password == "Coach123!";
                            Snackbar.Add("ברוך הבא! יש להשלים תהליך הרשמה ראשוני.", Severity.Info);
                            Nav.NavigateTo("coach/onboarding");
                            return;
                        }
                    }
                    catch
                    {
                        // If we can't check, assume onboarding needed
                        AppState.RequiresOnboarding = true;
                        Nav.NavigateTo("coach/onboarding");
                        return;
                    }
                }

                Snackbar.Add("ברוך הבא! התחברת בהצלחה.", Severity.Success);
                Nav.NavigateTo(AppState.IsAdmin ? "admin/dashboard" : "coach/assignments");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"שגיאת התחברות: {ex.Message}", Severity.Error);
        }
        finally
        {
            loading = false;
        }
    }
}
